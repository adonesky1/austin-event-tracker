# DATABASE_URL
# Required: Yes. Used for the app's PostgreSQL connection string.
# How to get it: For local Docker Compose, keep the default localhost value below.
# On a VPS with docker-compose, change host to `db`. For managed Postgres, copy the connection URL from your DB provider.
# Local vs VPS: Usually different. Locally this file defaults to `localhost`; on the VPS docker-compose deployment use `db` as the hostname.
DATABASE_URL=postgresql+asyncpg://events:events@localhost:5432/events

# ANTHROPIC_API_KEY
# Required: Yes. Used for AI enrichment and curation text/ranking support.
# How to get it: Create an API key at https://console.anthropic.com/
# Local vs VPS: Usually the same format in both places. You can reuse one key or keep separate dev/prod keys.
ANTHROPIC_API_KEY=sk-ant-...

# RESEND_API_KEY
# Required: Yes for sending email digests. Used by the email notification channel.
# How to get it: Create an API key in the Resend dashboard at https://resend.com/
# Local vs VPS: Same kind of value in both places. Many teams use one key locally and a separate production key on the VPS.
RESEND_API_KEY=re_...

# EVENTBRITE_API_KEY
# Required: Recommended, but not strictly required. Used to ingest Eventbrite events.
# How to get it: Create an Eventbrite app/private token at https://www.eventbrite.com/platform/api
# Local vs VPS: Usually the same value in both environments unless you want separate API apps for testing.
EVENTBRITE_API_KEY=

# BANDSINTOWN_APP_ID
# Required: Recommended, but not strictly required. Used to ingest Bandsintown events.
# How to get it: Use any descriptive app name/string per Bandsintown's API docs:
# https://artists.bandsintown.com/support/api-installation
# Local vs VPS: Usually the same value in both environments.
BANDSINTOWN_APP_ID=

# ADMIN_API_KEY
# Required: Yes. Used to protect /admin endpoints.
# How to get it: Generate a random secret, e.g.
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Local vs VPS: Can be different. It's fine to use a simple local dev key, but the VPS should use a strong random secret.
# Admin UI note: If you deploy a separate admin UI on Vercel, keep this only in the VPS `.env` and Vercel server-side env vars. Never expose it in browser code.
ADMIN_API_KEY=changeme

# DEFAULT_CITY
# Required: No. Used to choose the city config to ingest/rank against.
# How to get it: Set to a city slug that exists under src/config/cities/. Current default is `austin`.
# Local vs VPS: Usually the same unless you are testing another city locally.
DEFAULT_CITY=austin

# DIGEST_SCHEDULE_DAYS
# Required: No. Used by the scheduler for the digest send days.
# How to get it: Set comma-separated APScheduler weekday values, e.g. `tue,fri`.
# Local vs VPS: Can differ. On a VPS these are your real send days; locally you may leave the default and trigger jobs manually.
DIGEST_SCHEDULE_DAYS=tue,fri

# DIGEST_HOUR
# Required: No. Used by the scheduler for the digest send hour in the app timezone.
# How to get it: Choose an integer hour in 24-hour time, e.g. `8` for 8 AM.
# Local vs VPS: Can differ. On a VPS this controls the live scheduled send; locally you can leave it alone and run jobs manually.
DIGEST_HOUR=8

# FROM_EMAIL
# Required: Yes for email delivery. Used as the sender address and default recipient in single-user mode.
# How to get it: Use an address on a domain verified in Resend, e.g. `digest@yourdomain.com`.
# Local vs VPS: Often different. Locally you might use a test/sandbox sender you control; on the VPS this should be your real verified production sender.
FROM_EMAIL=events@yourdomain.com

# BASE_URL
# Required: Yes. Used to generate links in digests and feedback pages.
# How to get it: Set to your app's public URL, e.g. http://localhost:8000 locally or https://yourdomain.com in production.
# Local vs VPS: Definitely different. Use `http://localhost:8000` locally and your public domain or VPS URL in production.
BASE_URL=http://localhost:8000

# FEEDBACK_SECRET
# Required: Yes. Used to sign feedback links in digests.
# How to get it: Generate a random secret, e.g.
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Local vs VPS: Can be different. It's fine to use a throwaway local value, but the VPS should use a strong random secret.
FEEDBACK_SECRET=changeme-to-random-string

# LOG_LEVEL
# Required: No. Used to control application log verbosity.
# How to get it: Use a standard level like DEBUG, INFO, WARNING, ERROR. Default is INFO.
# Local vs VPS: Often different. Local development may use `DEBUG`; the VPS usually stays on `INFO`.
LOG_LEVEL=INFO

# GOOGLE_CALENDAR_ENABLED
# Required: No. Enables publishing curated events to Google Calendar when `true`.
# How to get it: Set `true` only after configuring the Google Calendar values below.
# Local vs VPS: Can differ. Many people keep this `false` locally and `true` on the VPS after setup.
GOOGLE_CALENDAR_ENABLED=false

# GOOGLE_CALENDAR_CLIENT_ID
# Required: Only when GOOGLE_CALENDAR_ENABLED=true. Used for Google OAuth authentication.
# How to get it: Create a Desktop OAuth client in Google Cloud Console after enabling Google Calendar API:
# https://console.cloud.google.com/
# Local vs VPS: Usually the same value in both environments. You typically bootstrap locally, then copy the resulting values to the VPS.
GOOGLE_CALENDAR_CLIENT_ID=

# GOOGLE_CALENDAR_CLIENT_SECRET
# Required: Only when GOOGLE_CALENDAR_ENABLED=true. Used for Google OAuth authentication.
# How to get it: From the same Google Cloud OAuth client as GOOGLE_CALENDAR_CLIENT_ID.
# Local vs VPS: Usually the same value in both environments.
GOOGLE_CALENDAR_CLIENT_SECRET=

# GOOGLE_CALENDAR_REFRESH_TOKEN
# Required: Only when GOOGLE_CALENDAR_ENABLED=true. Used so the app can sync to Google Calendar without interactive login.
# How to get it: Run `python3 scripts/google_calendar_bootstrap.py path/to/oauth-client.json`.
# Local vs VPS: Usually the same value in both environments. Generate it locally via the browser-based bootstrap flow, then copy it to the VPS.
GOOGLE_CALENDAR_REFRESH_TOKEN=

# GOOGLE_CALENDAR_ID
# Required: Only when GOOGLE_CALENDAR_ENABLED=true. Used as the target Google Calendar to sync curated events into.
# How to get it: Run `python3 scripts/google_calendar_bootstrap.py path/to/oauth-client.json`, or copy the calendar ID from Google Calendar settings.
# Local vs VPS: Usually the same value in both environments because both should point at the same target shared calendar.
GOOGLE_CALENDAR_ID=

# GOOGLE_CALENDAR_MIN_SCORE
# Required: No. Used as the minimum final curation score for calendar publishing.
# How to get it: Choose a float between 0 and 1. Default `0.65` is a balanced threshold.
# Local vs VPS: Can differ. You might lower it locally for testing, but the VPS should use the production threshold you actually want subscribers to see.
GOOGLE_CALENDAR_MIN_SCORE=0.65

# GOOGLE_CALENDAR_HORIZON_DAYS
# Required: No. Used as the number of days ahead to publish events into the calendar.
# How to get it: Choose an integer day window. Default `21` matches the current digest horizon.
# Local vs VPS: Can differ, though many setups keep it the same in both places.
GOOGLE_CALENDAR_HORIZON_DAYS=21

# GOOGLE_CALENDAR_FALLBACK_DURATION_MINUTES
# Required: No. Used when a source does not provide an event end time.
# How to get it: Choose an integer duration in minutes. Default is `120`.
# Local vs VPS: Usually the same in both environments.
GOOGLE_CALENDAR_FALLBACK_DURATION_MINUTES=120

# GOOGLE_CALENDAR_SYNC_HOUR
# Required: No. Used by the scheduler for the daily Google Calendar sync hour.
# How to get it: Choose an integer hour in 24-hour time. Default is `7` (7 AM).
# Local vs VPS: Can differ. On the VPS this controls the real scheduled sync; locally it usually matters less if you trigger sync manually.
GOOGLE_CALENDAR_SYNC_HOUR=7

# GOOGLE_CALENDAR_TIMEZONE
# Required: No. Used for the Google Calendar sync schedule and event timezone fallback.
# How to get it: Use an IANA timezone name, e.g. `America/Chicago`.
# Local vs VPS: Usually the same unless you are intentionally testing another timezone locally.
GOOGLE_CALENDAR_TIMEZONE=America/Chicago

# GOOGLE_CALENDAR_CALENDAR_NAME
# Required: No. Used as the default display name when creating the Google Calendar.
# How to get it: Pick any descriptive calendar title. Default is `Austin Curated Events`.
# Local vs VPS: Usually the same. It mainly matters during initial bootstrap/calendar creation.
GOOGLE_CALENDAR_CALENDAR_NAME=Austin Curated Events
