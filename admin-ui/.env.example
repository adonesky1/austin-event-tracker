# BACKEND_BASE_URL
# Required: Yes. Used by the Vercel admin UI server routes to call the VPS-hosted FastAPI backend.
# How to get it: Use the public base URL for your backend API, e.g. `https://api.yourdomain.com`.
# Local vs Vercel: Usually different. Locally you may use `http://localhost:8000`; on Vercel use the public HTTPS backend URL.
BACKEND_BASE_URL=

# BACKEND_ADMIN_API_KEY
# Required: Yes. Used for server-to-server authentication from the Vercel app to the VPS `/admin` API.
# How to get it: Copy the exact `ADMIN_API_KEY` value from the backend VPS `.env`.
# Local vs Vercel: Often the same if both environments target the same backend, but it can differ if local admin-ui points at a different local backend.
# Security note: Server-side only. Never expose this in `NEXT_PUBLIC_*` env vars or browser code.
BACKEND_ADMIN_API_KEY=

# AUTH_SECRET
# Required: Yes. Used by Auth.js to sign session cookies and auth state.
# How to get it: Generate a strong random string, e.g. `openssl rand -base64 32` or `python3 -c "import secrets; print(secrets.token_urlsafe(32))"`.
# Local vs Vercel: Can differ. A throwaway local secret is okay; Vercel should use a strong stable production secret.
AUTH_SECRET=

# AUTH_GOOGLE_ID
# Required: Yes. Used for Google sign-in to the admin UI.
# How to get it: Create a Google OAuth client in Google Cloud and add your local/Vercel callback URLs.
# Local vs Vercel: May differ if you use separate OAuth clients, but many teams reuse one client with both localhost and production callback URLs.
AUTH_GOOGLE_ID=

# AUTH_GOOGLE_SECRET
# Required: Yes. Paired secret for AUTH_GOOGLE_ID.
# How to get it: From the same Google Cloud OAuth client as AUTH_GOOGLE_ID.
# Local vs Vercel: Usually matches AUTH_GOOGLE_ID usage; may differ if you use separate clients per environment.
AUTH_GOOGLE_SECRET=

# ADMIN_ALLOWED_EMAILS
# Required: Yes in practice. Used to restrict admin UI access to specific Google accounts.
# How to get it: Add a comma-separated list of the Google account emails that should be allowed to sign in.
# Local vs Vercel: Can differ. Locally you may allow only yourself; on Vercel you may include additional trusted operators.
ADMIN_ALLOWED_EMAILS=you@example.com
